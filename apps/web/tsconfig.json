{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@wayra/types": ["../../packages/types/src/index.ts"],
      "@wayra/types/*": ["../../packages/types/src/*"],
      "@wayra/shared": ["../../packages/shared/src/index.ts"],
      "@wayra/i18n": ["../../packages/i18n/src/index.ts"],
      "@wayra/i18n/*": ["../../packages/i18n/src/*"],
      "@wayra/ui": ["../../packages/ui/src/index.ts"],
      "@wayra/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
