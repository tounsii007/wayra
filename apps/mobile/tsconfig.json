{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@wayra/types": ["../../packages/types/src/index.ts"],
      "@wayra/shared": ["../../packages/shared/src/index.ts"],
      "@wayra/i18n": ["../../packages/i18n/src/index.ts"],
      "@wayra/i18n/*": ["../../packages/i18n/src/*"],
      "@wayra/ui": ["../../packages/ui/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
