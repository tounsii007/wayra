# ============================================================
# Wayra — Environment Variables (copy to .env)
# ============================================================

# --- Backend ---
NODE_ENV=development
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://wayra:wayra@localhost:5432/wayra
POSTGRES_USER=wayra
POSTGRES_PASSWORD=wayra
POSTGRES_DB=wayra

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-please-use-long-random-string
JWT_EXPIRES_IN=7d

# --- External APIs (optional) ---
# Deutsche Bahn / DB API
DB_API_KEY=
DB_CLIENT_ID=

# SNCF (France)
SNCF_API_KEY=

# OpenStreetMap / Nominatim
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Mapbox / MapLibre tiles
MAPTILER_API_KEY=
MAPBOX_ACCESS_TOKEN=

# AI Assistant (Anthropic Claude)
ANTHROPIC_API_KEY=

# --- Web (Next.js public vars) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_MAPTILER_KEY=
NEXT_PUBLIC_DEFAULT_COUNTRY=DE

# --- Mobile (Expo) ---
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_MAPTILER_KEY=
